{
  "name": "tl-dw",
  "version": "0.1.162",
  "description": "TL;DW (Too Long; Didn't Watch) sends the current YouTube video to Gemini, ChatGPT, Claude, or NotebookLM in one keystroke.",
  "private": true,
  "license": "MIT",
  "author": "Nathan Watkins",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "build": "node scripts/build-release.mjs",
    "package": "node scripts/package-store.mjs"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.0.0-beta.28",
    "@types/chrome": "^0.0.287",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "vitest": "^2.1.9"
  }
}
